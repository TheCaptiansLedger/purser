# Copy this file to .env and fill in your keys.
# This file documents both the seeder (cmd/seed) and the app (PURSER_ prefix) variables.

# ═══════════════════════════════════════════════════════════════════════════════
# APP CONFIGURATION (PURSER_ prefix, read by the Purser server)
# ═══════════════════════════════════════════════════════════════════════════════

# ── StashDB (adult + JAV) ────────────────────────────────────────────────────
# Log in at https://stashdb.org → Settings → API Key
# PURSER_SOURCES_STASHDB_ENABLED=true
# PURSER_SOURCES_STASHDB_API_KEY=

# ── TPDB (adult + JAV) ───────────────────────────────────────────────────────
# Get a key at https://theporndb.net
# PURSER_SOURCES_TPDB_ENABLED=true
# PURSER_SOURCES_TPDB_API_KEY=

# ── Stash (self-hosted, adult + JAV) ─────────────────────────────────────────
# URL is required; API key is optional if auth is disabled on your instance.
# PURSER_SOURCES_STASH_ENABLED=true
# PURSER_SOURCES_STASH_URL=http://stash.local:9999
# PURSER_SOURCES_STASH_API_KEY=

# ── TMDB (movies + TV) ───────────────────────────────────────────────────────
# Get the v4 "API Read Access Token" at https://www.themoviedb.org/settings/api
# Use the long bearer token, not the short API key.
# PURSER_SOURCES_TMDB_ENABLED=true
# PURSER_SOURCES_TMDB_API_KEY=

# ── TVDB (TV shows) ──────────────────────────────────────────────────────────
# Create an API key at https://thetvdb.com/dashboard/account/apikeys
# PURSER_SOURCES_TVDB_ENABLED=true
# PURSER_SOURCES_TVDB_API_KEY=

# ── MusicBrainz (music) ──────────────────────────────────────────────────────
# No API key required. Set a descriptive User-Agent per MusicBrainz policy.
# PURSER_SOURCES_MUSICBRAINZ_ENABLED=true
# PURSER_SOURCES_MUSICBRAINZ_USER_AGENT=purser/1.0 (you@example.com)

# ── TheAudioDB (music) ───────────────────────────────────────────────────────
# Free tier uses API key "123". Sign up at https://www.theaudiodb.com for a
# Patreon key if you need the v2 API (higher rate limits, more fields).
# PURSER_SOURCES_THEAUDIODB_ENABLED=true
# PURSER_SOURCES_THEAUDIODB_API_KEY=123

# ── Last.fm (music) ──────────────────────────────────────────────────────────
# Create an API key at https://www.last.fm/api/account/create
# PURSER_SOURCES_LASTFM_ENABLED=true
# PURSER_SOURCES_LASTFM_API_KEY=

# ── OpenLibrary (books) ───────────────────────────────────────────────────────
# No API key required.
# PURSER_SOURCES_OPENLIBRARY_ENABLED=true

# ── Optional path/port overrides ─────────────────────────────────────────────
# PURSER_DATABASE_DSN=/data/purser.db
# PURSER_MEDIA_PATH=/data/purser/images
# PURSER_MODULES_MOVIES_ROOTS=/mnt/disk1/movies,/mnt/disk2/movies
# PURSER_MODULES_TV_ROOTS=/nas/tv

# ═══════════════════════════════════════════════════════════════════════════════
# SEEDER CONFIGURATION (cmd/seed, read by the seed tool only)
# ═══════════════════════════════════════════════════════════════════════════════

# ── TMDB (movies + TV shows) ─────────────────────────────────────────────────
TMDB_API_KEY=

# ── StashDB (adult + JAV) ────────────────────────────────────────────────────
STASHDB_API_KEY=

# ── MusicBrainz ──────────────────────────────────────────────────────────────
# No key required. MusicBrainz asks for a descriptive User-Agent instead.
MUSICBRAINZ_APP=purser-seed/0.1
