# syntax=docker/dockerfile:1
# Build context must be the project root: podman build -f ops/Containerfile .
# ──────────────────────────────────────────────────────────────────────────────
# Stage 1: Build the React UI
# ──────────────────────────────────────────────────────────────────────────────
FROM node:22-slim AS ui-builder
WORKDIR /app/web

COPY web/package.json ./
RUN npm install

COPY web/ .
RUN npm run build

# ──────────────────────────────────────────────────────────────────────────────
# Stage 2: Build Go binary
# ──────────────────────────────────────────────────────────────────────────────
FROM golang:1.26-bookworm AS go-builder
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=ui-builder /app/web/dist ./web/dist

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/purser ./cmd/purser

# ──────────────────────────────────────────────────────────────────────────────
# Stage 3: Runtime image
# ──────────────────────────────────────────────────────────────────────────────
# distroless/static includes ca-certificates and tzdata; no shell, no package
# manager, no writable filesystem outside mounted volumes.
FROM gcr.io/distroless/static-debian12

COPY --from=go-builder /out/purser /usr/local/bin/purser

VOLUME ["/data", "/media/purser", "/media/content"]

EXPOSE 7474

ENTRYPOINT ["/usr/local/bin/purser"]
CMD ["--config", "/config/purser.yaml"]
