# syntax=docker/dockerfile:1
# Build context must be the project root.
# web/dist/ must be pre-built before calling docker build:
#   cd web && npm run build
# The Makefile dev target handles this automatically.
# ──────────────────────────────────────────────────────────────────────────────
# Stage 1: Build Go binary (web/dist/ is provided by the build context)
# ──────────────────────────────────────────────────────────────────────────────
FROM golang:1.26-bookworm AS go-builder
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
ARG COMMIT_SHA=unknown

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath \
    -ldflags="-s -w -X purser/internal/version.Version=${VERSION}" \
    -o /out/purser ./cmd/purser

# ──────────────────────────────────────────────────────────────────────────────
# Stage 2: Runtime image
# ──────────────────────────────────────────────────────────────────────────────
# distroless/static includes ca-certificates and tzdata; no shell, no package
# manager, no writable filesystem outside mounted volumes.
FROM gcr.io/distroless/static-debian12

COPY --from=go-builder /out/purser /usr/local/bin/purser

VOLUME ["/data", "/media/purser", "/media/content"]

EXPOSE 7474

ENTRYPOINT ["/usr/local/bin/purser"]
CMD ["--config", "/config/purser.yaml"]
